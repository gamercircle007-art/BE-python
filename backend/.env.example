# =============================================================================
# Paythan Backend — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to version control.
# =============================================================================

# --- Environment ---
APP_ENV=local
ENVIRONMENT=local
APP_NAME=paythan
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Database ---
DATABASE_URL=postgresql+asyncpg://paythan:changeme_postgres_password@localhost:5432/paythan
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT ---
JWT_SECRET_KEY=changeme_use_a_long_random_secret_key_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Auth methods ---
AUTH_METHODS=whatsapp_otp,password

# --- OTP ---
OTP_PROVIDER=twilio
OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_COUNT=5
OTP_RATE_LIMIT_WINDOW_MINUTES=10

# --- Login security ---
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# --- Argon2 ---
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=4

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:8080
CORS_ALLOW_CREDENTIALS=true

# --- Twilio WhatsApp ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=

# --- Email OTP (future) ---
EMAIL_OTP_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME=Paythan
EMAIL_USE_TLS=true

# --- Google OAuth (future) ---
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback

# --- Apple Sign In (future) ---
APPLE_OAUTH_ENABLED=false
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=
APPLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/apple/callback

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=false

# --- Security ---
ALLOWED_HOSTS=*