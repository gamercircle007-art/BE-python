# =============================================================================
# Paythan — Root Environment Variables (used by docker-compose)
# Copy to .env and fill in values. NEVER commit .env to version control.
# =============================================================================

# --- Environment ---
# local | dev | staging | prod
APP_ENV=local
ENVIRONMENT=local
APP_NAME=paythan
DEBUG=true

# --- PostgreSQL ---
POSTGRES_USER=paythan
POSTGRES_PASSWORD=changeme_postgres_password
POSTGRES_DB=paythan
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://paythan:changeme_postgres_password@postgres:5432/paythan

# --- Redis (OTP sessions, refresh tokens, login lockout) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- JWT (generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))") ---
JWT_SECRET_KEY=changeme_use_a_long_random_secret_key_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Auth methods (comma-separated, extensible) ---
# Current: whatsapp_otp,password
# Future:  google,apple,email_otp,sms_otp
AUTH_METHODS=whatsapp_otp,password

# --- OTP (WhatsApp signup) ---
OTP_PROVIDER=twilio
OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_COUNT=5
OTP_RATE_LIMIT_WINDOW_MINUTES=10

# --- Login brute-force protection ---
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# --- Argon2 password hashing (optional tuning) ---
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=4

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:8080

# --- Twilio WhatsApp OTP (primary signup channel) ---
# Sandbox: join via Twilio Console → use whatsapp:+14155238886
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Twilio SMS OTP fallback (future) ---
TWILIO_SMS_FROM=

# --- Email OTP alternative (future) ---
EMAIL_OTP_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME=Paythan
EMAIL_USE_TLS=true

# --- Google OAuth (future) ---
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback

# --- Apple Sign In (future) ---
APPLE_OAUTH_ENABLED=false
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=
APPLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/apple/callback

# --- Backend port ---
BACKEND_PORT=8000